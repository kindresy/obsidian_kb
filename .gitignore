# OS files
.DS_Store
Thumbs.db

# Temp files
*.base
*~

# Obsidian auto-generated (page preview cache)
.obsidian/page-preview.json

# Claude Code (environment-specific: settings, agent definitions, sessions)
.claude/

# Claudian Obsidian plugin (user sessions & settings)
.claudian/

# Obsidian workspace & graph layout (user-specific, auto-generated)
.obsidian/workspace.json
.obsidian/graph.json

# Obsidian plugin user config (differs per machine/user)
.obsidian/plugins/obsidian-git/data.json
.obsidian/plugins/realclaudian/data.json

# Obsidian themes (reinstallable via community themes browser)
.obsidian/themes/*

# Obsidian plugin binaries (reinstallable via community-plugins.json)
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css

# LLM Wiki vector index (rebuildable via build-index.py)
LLM_Wiki/.vector_index/

# Python cache
__pycache__/
*.pyc

# Kernel module build artifacts (rebuildable from source)
raw/code/**/*.o
raw/code/**/*.ko
raw/code/**/*.mod
raw/code/**/*.mod.c
raw/code/**/*.cmd
raw/code/**/Module.symvers
raw/code/**/modules.order
raw/code/**/.tmp_versions/
