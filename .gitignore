# OS files
.DS_Store
Thumbs.db

# Claude Code (environment-specific: settings, agent definitions, sessions)
.claude/

# Claudian Obsidian plugin (user sessions & settings)
.claudian/

# Obsidian user-specific config (differs per machine/user)
.obsidian/workspace.json
.obsidian/graph.json
.obsidian/plugins/*/data.json

# Obsidian plugin binaries (reinstallable via community-plugins.json)
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css

# LLM Wiki vector index (rebuildable via build-index.py)
LLM_Wiki/.vector_index/

# Python cache
__pycache__/
*.pyc

# Kernel module build artifacts (rebuildable from source)
raw/code/**/*.o
raw/code/**/*.ko
raw/code/**/*.mod
raw/code/**/*.mod.c
raw/code/**/*.cmd
raw/code/**/Module.symvers
raw/code/**/modules.order
raw/code/**/.tmp_versions/
